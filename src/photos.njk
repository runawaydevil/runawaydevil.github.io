---
layout: page.njk
title: Photos
pagination:
  data: collections.photo
  size: 15
  alias: posts
  reverse: true
  generatePageOnEmptyData: true
---

<section class="photos-intro" aria-labelledby="photos-page-heading">
  <p>{% icon "image", "sm", true %} My photo log — snapshots and experiments in light.</p>
  <p>Browse the grid below; each thumbnail links to the full post and its caption.</p>
</section>

<div class="h-feed h-feed--entries h-feed--photos">
  <h2 id="photos-page-heading" class="p-name sr-only">Photos</h2>
  <div class="h-feed__mf2" aria-hidden="true">
    <a class="u-url" href="/photos/"></a>
    <a rel="author" class="p-author h-card" href="/">Pablo Murad</a>
  </div>

  <ul class="post-list">
  {% for post in posts %}
    <li class="h-entry photo-archive-item">
      <a class="u-url sr-only" href="{{ post.url }}">{{ post | homeTitle }}</a>
      <span class="p-name sr-only">Photo</span>
      <time class="dt-published sr-only" datetime="{{ post.date | dateToISO }}">{{ post.date.toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'long', day: 'numeric' }) }}</time>
      <span class="p-author h-card mf2-only"><a rel="author" href="/">Pablo Murad</a></span>
      {% set first = post.data.photos and post.data.photos[0] %}
      {% set photoUrl = null %}
      {% set photoAlt = "Photo" %}
      {% if first %}
        {% set photoUrl = first %}
        {% if first.url %}
          {% set photoUrl = first.url %}
        {% elif first.value %}
          {% set photoUrl = first.value %}
        {% endif %}
        {% set photoUrl = photoUrl | replace('/src/', '/') %}
        {% if first.alt %}
          {% set photoAlt = first.alt %}
        {% endif %}
      {% endif %}
      <div class="photo-archive-item__thumb-wrap photo-vintage">
        <a class="photo-archive-item__img-link" href="{{ post.url }}" tabindex="-1" aria-hidden="true">
          {% if photoUrl %}
            <img class="u-photo photo-archive-item__thumb" src="{{ photoUrl }}" alt="" loading="lazy" decoding="async" width="400" height="300" />
          {% else %}
            <div class="photo-archive-item__thumb-placeholder" aria-hidden="true">{% icon "image", "md", true %}</div>
          {% endif %}
        </a>
      </div>
      <div class="photo-archive-item__body">
        {% set cap = post | homeSummary(40) %}
        {% if cap %}
        <p class="p-summary photo-archive-item__summary">{{ cap }}</p>
        {% endif %}
        <p class="photo-archive-item__continue"><a href="{{ post.url }}">Read full post</a></p>
      </div>
    </li>
  {% else %}
    <li class="empty-archive-item">{% glyph "empty-state", "md", true, "", "icon--empty" %} <em class="empty-archive__hint">No photos yet.</em></li>
  {% endfor %}
  </ul>

  {% if pagination.pages and pagination.pages.length > 1 %}
  <nav class="pagination" aria-label="Pagination">
    <div>
      {% if pagination.href.previous %}
        <a href="{{ pagination.href.previous }}">{% icon "chevron-left", "sm", true %} Newer entries</a>
      {% endif %}
    </div>
    {% if pagination.pages and pagination.pages.length > 1 %}
    <div class="pagination__status" role="status">Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</div>
    {% endif %}
    <div>
      {% if pagination.href.next %}
        <a href="{{ pagination.href.next }}">Older entries {% icon "chevron-right", "sm", true %}</a>
      {% endif %}
    </div>
  </nav>
  {% endif %}
</div>
