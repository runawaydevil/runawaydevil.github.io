                    </svg>
                </div>
                <img class="u-photo" src="/assets/images/pablo.jpg" alt="Pablo Murad" width="80" height="80" style="border-radius: 50%; object-fit: cover; margin-bottom: 1rem;">
                
                <a class="p-name u-url u-uid" rel="me" href="https://pablo.space/" style="font-weight: bold; color: var(--text-color); text-decoration: none; margin-bottom: 0.4rem; display: block; font-size: 1.1em;">Pablo Murad</a>
                
                <a href="https://proof.1208.pro" title="Proof" style="display: block; margin-bottom: 0.8rem;">
                    <img src="/assets/images/verify.svg" alt="Verify" style="height: 1.2em; width: auto;">
                </a>
                
                <p class="p-note" style="margin: 0 0 1.2rem 0; color: var(--text-muted); font-size: 0.95em;">Wandering through strange worlds woven into the web.</p>

                {# Extended h-card properties for mf2 validators (e.g. IndieWebify); visually hidden #}
                <div class="mf2-only">
                    <span class="p-locality">São Lourenço</span>
                    <span class="p-region">Minas Gerais</span>
                    <span class="p-country-name">Brazil</span>
                    <span class="p-postal-code">37470-000</span>
                    <time class="dt-bday" datetime="1987-08-12">12 de agosto de 1987</time>
                    <span class="p-job-title">CEO &amp; Founder</span>
                    <span class="p-sex">Male</span>
                </div>
                
                <div style="display: flex; gap: 0.8rem; flex-wrap: wrap; justify-content: center; font-size: 0.9em; margin-bottom: 2rem;">
                    <a class="u-email" href="mailto:pablomurad@pm.me" style="color: var(--text-muted); text-decoration: none;">pablomurad<span style="color:var(--accent-color);">[at]</span>pm<span style="color:var(--accent-color);">[dot]</span>me</a>
                    <span style="color: var(--border-color, #333);">·</span>
                    <a class="u-url" rel="me" href="https://github.com/runawaydevil" style="color: var(--text-muted); text-decoration: none;">GitHub</a>
                    <span style="color: var(--border-color, #333);">·</span>
                    <a class="u-url" rel="me" href="https://bsky.app/profile/pablomurad.bsky.social" style="color: var(--text-muted); text-decoration: none;">Bluesky</a>
                    <span style="color: var(--border-color, #333);">·</span>
                    <a class="u-url" rel="me" href="https://social.lol/@runawaydevil" style="color: var(--text-muted); text-decoration: none;">Mastodon</a>
                    <span style="color: var(--border-color, #333);">·</span>
                    <a class="u-url" rel="me" href="https://twitter.com/runawayd3vil" style="color: var(--text-muted); text-decoration: none;">X</a>
                </div>

                <div class="meta" style="font-size: 0.85em; display: flex; flex-direction: column; gap: 0.5rem; align-items: center;">
                    <div class="webring" style="opacity: 0.7;">
                        <a href="https://xn--sr8hvo.ws/previous" style="text-decoration: none; color: inherit;">←</a> 
                        An <a href="https://xn--sr8hvo.ws" style="color: inherit;">IndieWeb Webring</a> 🕸💍 
                        <a href="https://xn--sr8hvo.ws/next" style="text-decoration: none; color: inherit;">→</a>
                    </div>
                    <p class="footer-feed-wrap" style="margin: 0 0 0.75rem 0;">
                        <a href="/feed.xml" class="footer-feed" style="color: var(--text-muted); text-decoration: none; border-bottom: none; display: inline-flex; align-items: center; gap: 0.35em;">
                            {% icon "rss", "sm", true %} RSS / Atom
                        </a>
                    </p>
                    <nav class="footer-sitemap" aria-label="Mapa do site">
                        <ul class="footer-sitemap__list">
                            <li><a href="/">Home</a></li>
                            <li><a href="/search/">Search</a></li>
                            <li><a href="/articles/">Articles</a></li>
                            <li><a href="/journal/">Journal</a></li>
                            <li><a href="/bookmarks/">Bookmarks</a></li>
                            <li><a href="/photos/">Photos</a></li>
                            <li><a href="/links/">Links</a></li>
                            <li><a href="/now/">Now</a></li>
                            <li><a href="/about/">About</a></li>
                            <li><a href="/guestbook/">Guestbook</a></li>
                            <li><a href="/contact/">Contact</a></li>
                        </ul>
                    </nav>
                    <div style="opacity: 0.6;">version 0.0.1</div>
                </div>
            </div>
        </footer>
    </div>
</body>
</html>
