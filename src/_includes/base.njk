<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title if title else "Being Pablo" }}</title>
    <meta name="description" content="Pablo's Space - Wandering through strange worlds woven into the web.">
    
    <!-- Feed Discovery -->
    <link rel="alternate" type="application/atom+xml" title="Pablo's Journal" href="/feed.xml">
    
    <!-- IndieWeb Rel=Me Links -->
    <link rel="me" href="mailto:pablomurad@pm.me">
    <link rel="me" href="https://pablo.space/">
    <link rel="me" href="https://github.com/runawaydevil">
    <link rel="me" href="https://bsky.app/profile/pablomurad.bsky.social">
    <link rel="me" href="https://social.lol/@runawaydevil">
    <link rel="me" href="https://twitter.com/runawayd3vil">
    <link rel="authorization_endpoint" href="https://pub.dega.wtf/auth">
    <link rel="token_endpoint" href="https://pub.dega.wtf/auth/token">
    <link rel="micropub" href="https://pub.dega.wtf/micropub">

    <!-- Favicon -->
    <link rel="icon" href="/assets/pets.ico" type="image/x-icon">

    <link rel="stylesheet" href="/assets/css/style.css">
    {% if usePagefind %}
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css">
    {% endif %}
    <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
</head>
<body>
    <a href="#main-content" class="skip-link">Ir para o conteúdo</a>
    <div class="site-wrapper">
        <header>
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: var(--space-md);">
                <a href="/" class="site-title" style="margin-bottom: 0; display: inline-flex; align-items: center; gap: 0.4em;">{% icon "home", "sm", true %} Being Pablo</a>
                <lottie-player src="/assets/images/sleep.json" background="transparent" speed="1" style="width: 48px; height: 48px; filter: invert(1);" loop autoplay></lottie-player>
            </div>
            {% include "nav.njk" %}
        </header>

        <main id="main-content" tabindex="-1">
            {{ content | safe }}
        </main>

        <!-- IndieWeb h-card -->
        <footer>
            <div class="h-card" style="display: flex; flex-direction: column; align-items: center; text-align: center;">
                <div style="width: 100%; max-width: 450px; margin-bottom: 2rem; opacity: 0.7; color: var(--text-color);">
                    <svg width="100%" viewBox="0 0 600 75" version="1.1" xmlns="http://www.w3.org/2000/svg" style="height: auto; stroke-linecap: round; stroke-linejoin: round; stroke-miterlimit: 1.5;">
