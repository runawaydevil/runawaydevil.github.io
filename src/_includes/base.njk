<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title if title else "Being Pablo" }}</title>
    <meta name="description" content="Pablo's Space - Wandering through strange worlds woven into the web.">
    
    <!-- Feed Discovery -->
    <link rel="alternate" type="application/atom+xml" title="Pablo's Journal" href="/feed.xml">
    
    <!-- IndieWeb Rel=Me Links -->
    <link rel="me" href="mailto:pablomurad@pm.me">
    <link rel="me" href="https://pablo.space/">
    <link rel="me" href="https://github.com/runawaydevil">
    <link rel="me" href="https://bsky.app/profile/pablomurad.bsky.social">
    <link rel="me" href="https://social.lol/@runawaydevil">
    <link rel="me" href="https://twitter.com/runawayd3vil">
    <link rel="authorization_endpoint" href="https://pub.dega.wtf/auth">
    <link rel="token_endpoint" href="https://pub.dega.wtf/auth/token">
    <link rel="micropub" href="https://pub.dega.wtf/micropub">

    <!-- Favicon -->
    <link rel="icon" href="/assets/pets.ico" type="image/x-icon">

    <!-- Preload self-hosted fonts (latin subsets; same URLs as @font-face in style.css) -->
    <link rel="preload" href="/assets/fonts/geist/geist-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/assets/fonts/geist-mono/geist-mono-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="stylesheet" href="/assets/css/style.css">
    {% if usePagefind %}
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css">
    {% endif %}
    {% if pagination and pagination.href %}
    {% if pagination.href.previous %}<link rel="prev" href="{{ pagination.href.previous }}">{% endif %}
    {% if pagination.href.next %}<link rel="next" href="{{ pagination.href.next }}">{% endif %}
    {% endif %}
</head>
<body>
    <a href="#main-content" class="skip-link">Ir para o conteúdo</a>
    <div class="site-wrapper">
        <header class="site-header">
            {% include "ansi-header.njk" %}
            {% include "nav.njk" %}
        </header>

        <main id="main-content" tabindex="-1">
            {{ content | safe }}
        </main>

        <!-- IndieWeb h-card: máquina no DOM; bloco decorativo oculto como .mf2-only -->
        <footer>
            <div class="footer-catito-divider" style="text-align: center; margin: 0 auto 2.5rem; max-width: 480px;">
                <img src="/assets/images/catito1.svg" alt="" aria-hidden="true" style="width: 100%; height: auto; max-height: 48px; object-fit: contain; opacity: 0.85;">
            </div>
            <div class="h-card site-footer-card">
                <div class="footer-hcard-visual-hide">
                <div class="site-footer-ornament">
                    <svg width="100%" viewBox="0 0 600 75" version="1.1" xmlns="http://www.w3.org/2000/svg" style="height: auto; stroke-linecap: round; stroke-linejoin: round; stroke-miterlimit: 1.5;">
                        <path transform="matrix(1,0,0,1,92.3579,4.11772)" d="M105.809,48.397C105.809,44.506 102.473,43.931 102.473,33.503" style="fill: none; stroke: currentColor; stroke-width: 1.5px;"/>
                        <path transform="matrix(1,0,0,1,92.3579,4.11772)" d="M109.397,38.324L109.397,48.321" style="fill: none; stroke: currentColor; stroke-width: 1.5px;"/>
                        <path transform="matrix(1,0,0,1,92.3579,4.11772)" d="M112.883,48.152C112.883,44.717 115.053,40.554 115.053,35.084C115.053,29.613 114.393,24.795 114.216,21.81" style="fill: none; stroke: currentColor; stroke-width: 1.5px;"/>
                        <path transform="matrix(1,0,0,1,92.3579,4.11772)" d="M112.951,22.241C112.951,22.241 116.335,21.976 117.504,16.695" style="fill: none; stroke: currentColor; stroke-width: 1.5px;"/>
                        <path transform="matrix(1,0,0,1,92.3579,4.11772)" d="M107.788,11.843C107.788,11.843 106.369,7.434 105.169,7.434C103.969,7.434 101.87,13.187 101.87,21.862C101.87,24.103 90.181,29.985 92.659,43.571C93.057,45.751 94.053,49.908 94.053,49.924C94.053,49.94 96.571,59.453 91.184,59.453C90.063,59.453 89.526,58.833 88.405,58.833C87.285,58.833 86.381,59.598 86.381,60.591C86.381,61.584 87.491,64.025 91.446,64.025C98.593,64.025 98.865,58.038 98.865,54.158C98.865,50.278 98.829,51.479 98.829,50.844C98.829,48.717 100.601,48.284 101.259,48.043" style="fill: none; stroke: currentColor; stroke-width: 1.5px;"/>
                        <ellipse transform="matrix(1.00474,-0.404483,0.370766,0.920982,85.4108,49.8267)" cx="111.892" cy="15.766" rx="1.032" ry="1.449" style="fill: currentColor;"/>
                        <path transform="matrix(1,0,0,1,92.3579,4.11772)" d="M110.074,10.347C113.617,10.347 114.448,14.635 117.14,14.635" style="fill: none; stroke: currentColor; stroke-width: 1.5px;"/>
                        <path transform="matrix(1,0,0,1,92.3579,4.11772)" d="M112.568,9.074C112.568,9.074 111.553,6.74 110.677,6.74C109.801,6.74 108.537,9.169 108.537,9.169" style="fill: none; stroke: currentColor; stroke-width: 1.5px;"/>
                        <path transform="matrix(3.96613,0,0,5.89452,-177.012,-336.835)" d="M93.717,66.428L195.647,66.428" style="fill: none; stroke: currentColor; stroke-width: 0.3px;"/>
                        <path transform="matrix(1.78906,0,0,2.78204,-166.7,-130.078)" d="M93.717,66.428L195.647,66.428" style="fill: none; stroke: currentColor; stroke-width: 0.64px;"/>
                    </svg>
                </div>
                <img class="u-photo site-footer-photo" src="/assets/images/pablo.jpg" alt="Pablo Murad" width="80" height="80">
                
                <a class="p-name u-url u-uid site-footer-name" rel="me" href="https://pablo.space/">Pablo Murad</a>
                
                <span class="site-footer-proof" title="Proof">
                    <img src="/assets/images/verify.svg" alt="">
                </span>
                
                <p class="p-note site-footer-note">Wandering through strange worlds woven into the web.</p>

                {# Extended h-card properties for mf2 validators (e.g. IndieWebify); visually hidden #}
                <div class="mf2-only">
                    <span class="p-locality">São Lourenço</span>
                    <span class="p-region">Minas Gerais</span>
                    <span class="p-country-name">Brazil</span>
                    <span class="p-postal-code">37470-000</span>
                    <time class="dt-bday" datetime="1987-08-12">12 de agosto de 1987</time>
                    <span class="p-job-title">CEO &amp; Founder</span>
                    <span class="p-sex">Male</span>
                </div>
                
                <div class="site-footer-links">
                    <a class="u-email" href="mailto:pablomurad@pm.me">pablomurad<span style="color:var(--accent-color);">[at]</span>pm<span style="color:var(--accent-color);">[dot]</span>me</a>
                    <span class="site-footer-dot">·</span>
                    <a class="u-url" rel="me" href="https://github.com/runawaydevil">GitHub</a>
                    <span class="site-footer-dot">·</span>
                    <a class="u-url" rel="me" href="https://bsky.app/profile/pablomurad.bsky.social">Bluesky</a>
                    <span class="site-footer-dot">·</span>
                    <a class="u-url" rel="me" href="https://social.lol/@runawaydevil">Mastodon</a>
                    <span class="site-footer-dot">·</span>
                    <a class="u-url" rel="me" href="https://twitter.com/runawayd3vil">X</a>
                </div>
                </div>

                <div class="meta site-footer-meta">
                    <p class="site-footer-proof-contact">
                        <a href="https://proof.1208.pro" class="site-footer-proof-contact-link">
                            <img src="/assets/images/verify.svg" alt="" width="16" height="16" class="site-footer-verify-inline" decoding="async">
                        </a>
                        <code class="site-footer-proof-email">pablomurad[at]pm[dot]me</code>
                    </p>
                    <div class="webring">
                        <a href="https://xn--sr8hvo.ws/previous" class="site-footer-plain-link">←</a> 
                        An <a href="https://xn--sr8hvo.ws" class="site-footer-plain-link">IndieWeb Webring</a> 🕸💍 
                        <a href="https://xn--sr8hvo.ws/next" class="site-footer-plain-link">→</a>
                    </div>
                    <p class="footer-feed-wrap">
                        <a href="/feed.xml" class="footer-feed">{% icon "rss", "sm", true %} RSS / Atom</a>
                        <span class="site-footer-dot" aria-hidden="true">·</span>
                        <a href="/colophon/" class="footer-feed">Colophon</a>
                    </p>
                    <div class="site-footer-credits">
                        <div class="site-footer-version">
                            <span class="site-footer-version-line">version {{ siteVersion }} — {{ siteVersionYear }}</span>
                            {% if buildFooter.sha or buildFooter.subject %}
                            <span class="site-footer-build" translate="no">
                                {% if buildFooter.sha %}<kbd class="site-footer-build-sha">{{ buildFooter.sha }}</kbd>{% endif %}
                                {% if buildFooter.sha and buildFooter.subject %}<span class="site-footer-build-sep" aria-hidden="true">·</span>{% endif %}
                                {% if buildFooter.subject %}<span class="site-footer-build-subject">{{ buildFooter.subject }}</span>{% endif %}
                            </span>
                            {% endif %}
                        </div>
                        <p class="site-footer-powered">
                            <a href="https://pages.github.com/" class="site-footer-powered-link" rel="noopener noreferrer">Powered by GitHub</a>
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </div>
    <script src="/assets/js/external-embeds.js" defer></script>
</body>
</html>
