---
layout: base.njk
---
<article class="h-entry">
  <header>
    {% if replyTo %}
      <div class="meta post-reply-context">
        <span class="post-reply-context__label">↩ Replying to:</span> <a href="{{ replyTo }}" class="u-in-reply-to post-reply-context__link">{{ replyTo | replace('https://', '') | replace('http://', '') }}</a>
      </div>
    {% endif %}

    {% if globalNoteId %}
      <h1 class="p-name">Note #{{ globalNoteId }}{% if title %} &mdash; {{ title }}{% endif %}</h1>
    {% elif title %}
      <h1 class="p-name">{{ title }}</h1>
    {% endif %}
    
    <div class="meta post-meta">
      <span class="post-meta__line">{% icon "calendar", "sm", true %} Published on <time class="dt-published" datetime="{{ page.date | dateToISO }}">{{ page.date.toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'long', day: 'numeric' }) }}</time></span>
      {% if updated %}
        (Updated: <time class="dt-updated" datetime="{{ updated | dateToISO }}">{{ updated.toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'long', day: 'numeric' }) if updated.toLocaleDateString else updated }}</time>)
      {% endif %}
      <a class="u-url mf2-only" href="{{ page.url }}">Permalink</a>
      <a rel="author" class="p-author h-card mf2-only" href="/">Pablo Murad</a>
    </div>
  </header>

  <nav class="post-toc" id="post-toc" aria-labelledby="post-toc-heading" hidden>
    <h2 id="post-toc-heading" class="post-toc__title">On this page</h2>
    <ol class="post-toc__list" id="post-toc-list"></ol>
  </nav>

  <div id="reading-progress-bar" class="reading-progress" aria-hidden="true"></div>

  <div class="e-content">
    {% if likeOf %}
       <div class="post-indie-block">
          <span class="micro-label">{% icon "heart", "sm", true %} Liked:</span> <a href="{{ likeOf }}" class="u-like-of post-indie-block__link">{{ likeOf }}</a>
       </div>
    {% endif %}

    {% if bookmarkOf %}
       <div class="post-indie-block">
          <span class="micro-label">{% icon "bookmark", "sm", true %} Bookmarked:</span> <a href="{{ bookmarkOf }}" class="u-bookmark-of post-indie-block__link">{{ bookmarkOf }}</a>
       </div>
    {% endif %}

    {% if photos %}
       <div class="post-photos">
       {% for photo in photos %}
          {% set photoUrl = photo %}
          {% if photo.url %}
            {% set photoUrl = photo.url %}
          {% elif photo.value %}
            {% set photoUrl = photo.value %}
          {% endif %}
          {% set finalUrl = photoUrl | replace('/src/', '/') %}
          {% set photoAlt = photo.alt if photo.alt else "Photo" %}
          <span class="photo-vintage"><img src="{{ finalUrl }}" alt="{{ photoAlt }}" class="u-photo post-photo"></span>
       {% endfor %}
       </div>
    {% endif %}

    {{ content | safe }}
  </div>

  {% if globalNoteId %}
    {% set rel = collections.journalNotes | reverse | relatedItems(page.url, 3) %}
  {% elif '/articles/' in page.inputPath %}
    {% set rel = collections.article | reverse | relatedItems(page.url, 3) %}
  {% else %}
    {% set rel = [] %}
  {% endif %}
  {% if rel | length %}
  <section class="related-posts" aria-labelledby="related-heading">
    <h2 id="related-heading" class="related-posts__title"><span class="related-posts__title-inner">{% icon "book-open", "sm", true %} Leia também</span></h2>
    <ul class="related-posts__list">
      {% for p in rel %}
      <li>
        <a href="{{ p.url }}">
          {% if p.data.globalNoteId %}
            Note #{{ p.data.globalNoteId }}{% if p.data.title %} — {{ p.data.title }}{% endif %}
          {% else %}
            {{ p.data.title | default('Untitled') }}
          {% endif %}
        </a>
        <time class="related-posts__date" datetime="{{ p.date | dateToISO }}">{{ p.date.toLocaleDateString('en-US', { timeZone: 'UTC', month: 'short', day: 'numeric', year: 'numeric' }) }}</time>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <footer class="post-footer">
    {% if '/journal/' in page.inputPath %}
      {% set activeCollectionName = 'journalNotes' %}
    {% elif '/articles/' in page.inputPath %}
      {% set activeCollectionName = 'article' %}
    {% elif '/bookmarks/' in page.inputPath %}
      {% set activeCollectionName = 'bookmark' %}
    {% elif '/photos/' in page.inputPath %}
      {% set activeCollectionName = 'photo' %}
    {% else %}
      {% set activeCollectionName = 'post' %}
    {% endif %}
    {% set activeCollection = collections[activeCollectionName] if collections[activeCollectionName] else collections.post %}
    {% set previousPost = activeCollection | getPreviousCollectionItem(page) %}
    {% set nextPost = activeCollection | getNextCollectionItem(page) %}
    
    <nav class="post-navigation" aria-label="Adjacent posts">
      <div>
        {% if previousPost %}
          {% set prevText = 'Note #' ~ previousPost.data.globalNoteId if previousPost.data.globalNoteId else previousPost.data.title | default('Previous') %}
          {% if previousPost.data.globalNoteId and previousPost.data.title %}
            {% set prevText = 'Note #' ~ previousPost.data.globalNoteId ~ ' &mdash; ' ~ previousPost.data.title %}
          {% endif %}
          <a href="{{ previousPost.url }}">{% icon "chevron-left", "sm", true %} {{ prevText | safe }}</a>
        {% endif %}
      </div>
      <div>
        {% if nextPost %}
          {% set nextText = 'Note #' ~ nextPost.data.globalNoteId if nextPost.data.globalNoteId else nextPost.data.title | default('Next') %}
          {% if nextPost.data.globalNoteId and nextPost.data.title %}
            {% set nextText = 'Note #' ~ nextPost.data.globalNoteId ~ ' &mdash; ' ~ nextPost.data.title %}
          {% endif %}
          <a href="{{ nextPost.url }}">{{ nextText | safe }} {% icon "chevron-right", "sm", true %}</a>
        {% endif %}
      </div>
    </nav>
  </footer>
</article>

<script src="/assets/js/post-toc.js" defer></script>
<script src="/assets/js/reading-progress.js" defer></script>

<section id="webmentions" class="webmentions-placeholder">
  <!-- Future integration point for Indiekit / Webmentions -->
</section>
