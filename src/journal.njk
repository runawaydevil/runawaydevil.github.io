---
layout: page.njk
title: Journal
pagination:
  data: collections.journalNotes
  size: 15
  alias: posts
  reverse: true
  generatePageOnEmptyData: true
---

<p>{% icon "notebook-pen", "sm", true %} Chronological notes from the journal stream.</p>

<div class="h-feed h-feed--entries">
  <h2 class="p-name sr-only">Pablo's Journal</h2>
  <div class="h-feed__mf2" aria-hidden="true">
    <a class="u-url" href="/journal"></a>
    <a rel="author" class="p-author h-card" href="/">Pablo Murad</a>
  </div>
  
  <ul class="post-list">
  {% for post in posts %}
    <li class="h-entry">
      <h3 class="post-list__title">
        <a class="u-url p-name post-list__title-link" href="{{ post.url }}">
          Note #{{ post.data.globalNoteId }}{% if post.data.title %} &mdash; {{ post.data.title }}{% endif %}
        </a>
      </h3>
      <div class="meta h-feed__entry-meta">
        <time class="dt-published" datetime="{{ post.date | dateToISO }}">{{ post.date.toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'long', day: 'numeric' }) }}</time>
        <a rel="author" class="p-author h-card mf2-only" href="/">Pablo Murad</a>
      </div>
      {% set listSummary = post | homeSummary(28) %}
      {% if listSummary %}
      <p class="p-summary">{{ listSummary }}</p>
      {% endif %}
      <p class="post-list__read-more">
        <a href="{{ post.url }}">Read full note {% icon "chevron-right", "xs", true %}</a>
      </p>
    </li>
    {% if not loop.last %}
    <li class="post-divider" aria-hidden="true">
      {% glyph "ornament-divider", "lg", true, "", "icon--ornament" %}
    </li>
    {% endif %}
  {% else %}
    <li class="empty-archive-item">{% glyph "empty-state", "md", true, "", "icon--empty" %} <em class="empty-archive__hint">Entries coming soon.</em></li>
  {% endfor %}
  </ul>

  {% if pagination.pages and pagination.pages.length > 1 %}
  <nav class="pagination" aria-label="Pagination">
    <div>
      {% if pagination.href.previous %}
        <a href="{{ pagination.href.previous }}">{% icon "chevron-left", "sm", true %} Newer entries</a>
      {% endif %}
    </div>
    {% if pagination.pages and pagination.pages.length > 1 %}
    <div class="pagination__status" role="status">Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</div>
    {% endif %}
    <div>
      {% if pagination.href.next %}
        <a href="{{ pagination.href.next }}">Older entries {% icon "chevron-right", "sm", true %}</a>
      {% endif %}
    </div>
  </nav>
  {% endif %}
</div>
